{
  "name": "@zhafron/mcp-web-search",
  "version": "1.2.3",
  "type": "module",
  "description": "MCP server: Multi-provider web search (DuckDuckGo, Bing, SearXNG) with automatic fallback, and URL content extraction — no API keys required.",
  "main": "dist/src/server.js",
  "bin": {
    "mcp-web-search": "./dist/src/server.js"
  },
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/src/server.js",
    "dev": "tsx src/server.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "web",
    "search",
    "extraction",
    "html",
    "pdf",
    "readability",
    "turndown",
    "ai",
    "duckduckgo",
    "bing",
    "searxng",
    "multi-provider"
  ],
  "author": "tickernelz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tickernelz/mcp-web-search.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^24.1.0",
    "pdf-parse": "^1.1.1",
    "puppeteer-core": "^23.11.1",
    "turndown": "^7.2.2",
    "user-agents": "^1.1.669",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.11.30",
    "@types/turndown": "^5.0.6",
    "@types/user-agents": "^1.0.4",
    "prettier": "^3.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
